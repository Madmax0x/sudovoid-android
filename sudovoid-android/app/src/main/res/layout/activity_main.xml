<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_navy">

    <com.aryan.sudovoid.GridBackgroundView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Title bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:background="@color/titlebar_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SUDO"
                android:textColor="#8064A0DC"
                android:textSize="13sp"
                android:letterSpacing="0.25"
                android:fontFamily="monospace"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/restartBtn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="[ RESTART ]"
                android:textColor="#664DE0FF"
                android:textSize="10sp"
                android:letterSpacing="0.15"
                android:fontFamily="monospace"
                android:padding="6dp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#1E4DA0DC" />

        <!-- Output -->
        <ScrollView
            android:id="@+id/scroll"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:scrollbars="none"
            android:paddingStart="18dp"
            android:paddingEnd="18dp"
            android:paddingTop="14dp">

            <LinearLayout
                android:id="@+id/outputContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="12dp" />

        </ScrollView>

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#1E4DA0DC" />

        <!-- Input bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@color/titlebar_bg"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&gt;&gt;"
                android:textColor="#664DA0DC"
                android:textSize="13sp"
                android:fontFamily="monospace"
                android:layout_marginEnd="10dp" />

            <EditText
                android:id="@+id/stdinInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:hint="type input and press enter..."
                android:textColorHint="@color/hint_text"
                android:textColor="@color/cyan"
                android:textSize="14sp"
                android:fontFamily="monospace"
                android:inputType="number"
                android:imeOptions="actionDone"
                android:singleLine="true" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
